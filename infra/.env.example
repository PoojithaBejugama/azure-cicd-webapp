# ============================================
# ENVIRONMENT VARIABLES - TEMPLATE
# ============================================
# Copy this file to .env.dev, .env.staging, .env.prod
# and fill in your actual values
# DO NOT COMMIT .env files to git!

# Azure Subscription Configuration
# Get these from: az account show
SUBSCRIPTION_ID=your-subscription-id-here
TENANT_ID=your-tenant-id-here

# Azure Authentication (optional - use if not using az login)
# Get these from Azure AD -> App registrations
ARM_CLIENT_ID=your-client-id-here
ARM_CLIENT_SECRET=your-client-secret-here

# Terraform Variables
ENVIRONMENT=dev
LOCATION="Canada Central"
RESOURCE_PREFIX=pooja

# App Service Configuration
APP_SERVICE_SKU=B1
NODE_VERSION=18-lts
